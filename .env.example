# ── API ──────────────────────────────────────────────────────────
# Base URL of the sams-api backend (no trailing slash).
# Local dev:   http://localhost:5000
# Production:  your Render backend URL, e.g. https://sams-api.onrender.com
# NOTE: NEXT_PUBLIC_* vars are baked in at BUILD time and exposed to the
# browser — set this before building/deploying, and never put secrets here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# ── Auth (NextAuth) ──────────────────────────────────────────────
# Secret used to encrypt sessions/JWTs. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Canonical URL of THIS frontend app.
# Local dev:   http://localhost:3001
# Production:  your deployed frontend URL, e.g. https://sams-web.vercel.app
NEXTAUTH_URL=http://localhost:3001
